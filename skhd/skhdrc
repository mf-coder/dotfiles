# Window focus
#
# alt + j: Move focus south.
# alt + k: Move focus north.
# alt + h: Move focus west.
# alt + l: Move focus east.
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

# Window movement (within space)
#
# shift + alt + j: Move window south.
# shift + alt + k: Move window north.
# shift + alt + h: Move window west.
# shift + alt + l: Move window east.
# ctrl + alt + j: Move focus south and split.
# ctrl + alt + k: Move focus north and split.
# ctrl + alt + h: Move focus west and split.
# ctrl + alt + l: Move focus east and split.
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - h : yabai -m window --swap west
shift + alt - l : yabai -m window --swap east
ctrl + alt - j : yabai -m window --warp south
ctrl + alt - k : yabai -m window --warp north
ctrl + alt - h : yabai -m window --warp west
ctrl + alt - l : yabai -m window --warp east

# Window movement (across spaces)
#
# alt + p: Move window to next space.
# alt + n: Move window to previous space.
# alt + 1: Move window to space 1.
# alt + 2: Move window to space 2.
# alt + 3: Move window to space 3.
# alt + 4: Move window to space 4.
# alt + 5: Move window to space 5.
# alt + 6: Move window to space 6.
# alt + 7: Move window to space 7.
# alt + 8: Move window to space 8.
# alt + 9: Move window to space 9.
shift + alt - p : yabai -m window --space prev;
shift + alt - n : yabai -m window --space next;
shift + alt - 1 : yabai -m window --space 1;
shift + alt - 2 : yabai -m window --space 2;
shift + alt - 3 : yabai -m window --space 3;
shift + alt - 4 : yabai -m window --space 4;
shift + alt - 5 : yabai -m window --space 5;
shift + alt - 6 : yabai -m window --space 6;
shift + alt - 7 : yabai -m window --space 7;
shift + alt - 8 : yabai -m window --space 8;
shift + alt - 9 : yabai -m window --space 9;

# Modify layout
#
# alt - r: Rotate clockwise.
# alt - y: Mirror on Y-axis.
# alt - x: Mirror on X-axis.
# alt - t: Toggle floating mode.
alt - r : yabai -m space --rotate 270
alt - y : yabai -m space --mirror y-axis
alt - x : yabai -m space --mirror x-axis
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Window size
#
# alt + f: Maximize focused window.
# alt + e: Equalize window size.
alt - f : yabai -m window --toggle zoom-fullscreen
alt - e : yabai -m space --balance

# Yabai control
#
# ctrl + alt + q: Stop yabai.
# ctrl + alt + s: Start yabai.
# ctrl + alt + r: Restart yabai.
ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - r : yabai --restart-service
