# General
#
# bsp: Use binary space partioning.
# second_child: Prioritize splitting right and below.
yabai -m config layout bsp
yabai -m config window_placement second_child

# Padding
#
# top: Top padding.
# bottom: Bottom padding.
# left: Left padding.
# right: Right padding.
# window_gap: Padding between windows.
yabai -m config top_padding 12
yabai -m config bottom_padding 12
yabai -m config left_padding 12
yabai -m config right_padding 12
yabai -m config window_gap 12

# Mouse
#
# mouse_follows_focus: Move mouse to focused window.
# mouse_modifier: Set mouse modifier key to arg.
# mouse_action: Mod + left click does arg.
# mouse_action2: Mod + right click does arg.
# mouse_drop_action: Do arg whenever windows is dragged to other's center.
yabai -m config mouse_follows_focus on
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m mouse_drop_action swap

# Rules
#
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Reminders$" manage=off
yabai -m rule --add app="^Notes$" manage=off
yabai -m rule --add app="^Calendar$" manage=off
